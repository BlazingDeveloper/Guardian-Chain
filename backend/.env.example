# ChainGuardian Backend – Environment Variables
# Copy to .env and fill in your free API keys

# ── Blockchain ──────────────────────────────────────
# Alchemy (free): https://dashboard.alchemy.com/
ALCHEMY_KEY=your_alchemy_key_here

# Etherscan Sepolia (free): https://etherscan.io/myapikey
ETHERSCAN_KEY=your_etherscan_key_here

# ── Wallet Data ─────────────────────────────────────
# Moralis (free): https://admin.moralis.io/
MORALIS_KEY=your_moralis_key_here

# Dune Analytics (free): https://dune.com/settings/api
DUNE_KEY=your_dune_key_here

# ── AI Layer ────────────────────────────────────────
# Gemini (primary): https://aistudio.google.com/app/apikey
GEMINI_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# Grok (xAI): https://console.x.ai/
GROK_KEY=your_grok_key_here

# HuggingFace (free fallback): https://huggingface.co/settings/tokens
HF_KEY=your_hf_token_here

# ── Contracts ───────────────────────────────────────
INTENT_LOG_CONTRACT=0xYourDeployedIntentLogAddress
CLEAN_CONTRACT=0xYourCleanDemoContract
RUG_CONTRACT=0xYourRugTokenContract
MALICIOUS_CONTRACT=0xYourMaliciousContract

# Wallet private key to sign intent log txs (use a DEDICATED throw-away wallet)
LOG_WALLET_PRIVATE_KEY=0xYourPrivateKeyForLogging

# ── Server ──────────────────────────────────────────
PORT=3000
